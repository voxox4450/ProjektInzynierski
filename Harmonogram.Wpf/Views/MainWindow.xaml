<hc:Window x:Class="Harmonogram.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="https://github.com/fantasticfiasco/mvvm-dialogs"
        xmlns:local="clr-namespace:Harmonogram.Wpf"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:Harmonogram.Wpf.ViewModels" 
        xmlns:converters="clr-namespace:Harmonogram.Wpf.Converters" d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
           md:DialogServiceViews.IsRegistered="True"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <hc:Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BooltoVisConventer"/>
    </hc:Window.Resources>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding OpenLoginCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>


        </Grid.RowDefinitions>

        <!--Main Pannel-->
        <Menu Grid.Row="0" x:Name="menuMainPanel" FontSize="20" FontWeight="Light" Background="Transparent">
            <MenuItem Header="Menu" Background="Gray">
                <MenuItem Command="{Binding OpenAdminCommand}"
                          Visibility="{Binding IsLogged.IsAdmin, Converter={StaticResource BooltoVisConventer}}"
                          Header="Admin"/>
                




            </MenuItem>
        </Menu>


    </Grid>
</hc:Window>
